{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Start Nodemon (watch)",
      "type": "pwa-node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/backend/node_modules/.bin/nodemon",
      "runtimeArgs": [
        "--watch",
        "src",
        "--ext",
        "ts",
        "--exec",
        "npm run build && node --inspect=9229 dist/index.js"
      ],
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Attach to Node",
      "type": "pwa-node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "localRoot": "${workspaceFolder}/backend",
      "remoteRoot": "${workspaceFolder}/backend"
    }
  ],
  "compounds": [
    {
      "name": "Debug Backend (Watch)",
      "configurations": ["Start Nodemon (watch)", "Attach to Node"]
    }
  ]
}
{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Backend (ts-node)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-r", "ts-node/register"],
      "program": "${workspaceFolder}/backend/src/index.ts",
      "preLaunchTask": "npm: build",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": { "NODE_ENV": "development" },
      "sourceMaps": true
    },
    {
      "name": "Debug Backend (built)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "program": "${workspaceFolder}/backend/dist/index.js",
      "preLaunchTask": "npm: build",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "outFiles": ["${workspaceFolder}/backend/dist/**/*.js"],
      "sourceMaps": true
    }
  ]
}
